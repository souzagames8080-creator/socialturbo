{
  "entities": {
    "RifaConfig": {
      "title": "Configuração da Rifa",
      "description": "Configurações dinâmicas da rifa editáveis pelo admin.",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "descricao": { "type": "string" },
        "valor": { "type": "number" },
        "logoUrl": { "type": "string" },
        "corDestaque": { "type": "string" }
      }
    },
    "RifaNumero": {
      "title": "Rifa Numero",
      "description": "Dados de um número da rifa.",
      "type": "object",
      "properties": {
        "numero": { "type": "integer" },
        "nome": { "type": "string" },
        "whatsapp": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["disponivel", "reservado", "pago"]
        },
        "timestamp_reserva": { "type": "string", "format": "date-time" }
      },
      "required": ["numero", "status"]
    }
  },
  "firestore": {
    "config/geral": {
      "schema": "RifaConfig",
      "description": "Documento único de configuração global."
    },
    "rifa_numeros/{numeroId}": {
      "schema": "RifaNumero",
      "description": "Coleção de números da rifa."
    }
  }
}
