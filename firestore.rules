rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Validação de reserva de número
    function isValidReservation() {
      let data = request.resource.data;
      return data.status == 'reservado' && 
             data.keys().hasAll(['nome', 'whatsapp', 'status', 'numero', 'timestamp_reserva']) &&
             data.keys().size() == 5 &&
             data.nome is string && data.nome.size() > 2 &&
             data.whatsapp is string && data.whatsapp.size() >= 8;
    }

    match /rifas/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);

      match /numeros/{numeroId} {
        allow read: if true;
        
        // Dono tem controle total (para apagar, confirmar pago, etc)
        allow write: if isOwner(userId);

        // Público pode criar ou atualizar se estiver disponível e for uma reserva válida
        allow create, update: if (
          (resource == null || resource.data.status == 'disponivel') &&
          isValidReservation()
        );
      }
    }
  }
}
