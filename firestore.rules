rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isMasterAdmin() {
      return isSignedIn() && request.auth.token.email == 'souzagames8080@gmail.com';
    }

    // Validação de reserva de número
    function isValidReservation() {
      let data = request.resource.data;
      return data.status == 'reservado' && 
             data.keys().hasAll(['nome', 'whatsapp', 'status', 'numero', 'timestamp_reserva']) &&
             data.keys().size() == 5;
    }

    match /rifas/{userId} {
      allow read: if true;
      
      // Permitir escrita se for o dono ou master admin
      allow write: if (isOwner(userId) || isMasterAdmin()) && (
        // Se for o dono (não master), não pode alterar status ou expiraEm
        (isMasterAdmin() || (
          isOwner(userId) && 
          request.resource.data.status == resource.data.status &&
          request.resource.data.expiraEm == resource.data.expiraEm
        )) ||
        // Caso seja criação de conta nova (resource é null)
        (resource == null && isOwner(userId))
      );

      match /numeros/{numeroId} {
        allow read: if true;
        allow write: if isOwner(userId) || isMasterAdmin();

        allow create, update: if (
          (resource == null || resource.data.status == 'disponivel') &&
          isValidReservation()
        );
      }
    }

    match /rifas {
      allow list: if isMasterAdmin();
    }
  }
}
