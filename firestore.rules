rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'souzagames8080@gmail.com';
    }

    match /rifa_numeros/{numeroId} {
      allow read: if true;
      // ...
    }

    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
