{
  "manifest_version": 3,
  "name": "SocialTurbo Pro Extension",
  "version": "1.0.0",
  "description": "Captura automática de sessões para o SocialTurbo Pro",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "cookies",
    "tabs",
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.facebook.com/*",
    "https://*.messenger.com/*",
    "http://localhost:3000/*",
    "https://ais-dev-zixasjyas3up27harioref-10471001554.us-west2.run.app/*",
    "https://socialturbo.minhadivulgacao.com.br/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.facebook.com/*"],
      "js": ["content.js"]
    },
    {
      "matches": [
        "http://localhost:3000/*",
        "https://ais-dev-zixasjyas3up27harioref-10471001554.us-west2.run.app/*",
        "https://socialturbo.minhadivulgacao.com.br/*"
      ],
      "js": ["bridge.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["manifest.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
