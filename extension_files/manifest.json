{
  "manifest_version": 3,
  "name": "SocialTurbo Pro",
  "version": "1.1",
  "description": "Sincronização e acesso rápido ao SocialTurbo Pro",
  "background": {
    "service_worker": "bg.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "cookies",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.facebook.com/*",
    "https://*.run.app/*",
    "*://socialturbo.minhadivulgacao.com.br/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.run.app/*",
        "*://socialturbo.minhadivulgacao.com.br/*"
      ],
      "js": ["content.js"]
    }
  ]
}
