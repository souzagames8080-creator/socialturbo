{
  "manifest_version": 3,
  "name": "SocialTurbo Pro",
  "version": "1.0",
  "description": "Ferramenta auxiliar para conexão rápida ao SocialTurbo",
  "permissions": ["cookies", "activeTab", "storage"],
  "host_permissions": ["*://*.facebook.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  }
}
